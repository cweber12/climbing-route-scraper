# ── Render API URL (used by the local scraper to write data) ──────────────
# Set this to your deployed Render service URL once it is live.
# Leave blank to write directly to the database instead (local dev only).
API_URL=https://your-app-name.onrender.com

# ── Database (Neon or local PostgreSQL) ───────────────────────────────────
# Option A: full connection string (recommended — Neon provides this).
# When DATABASE_URL is set the individual DB_* vars below are ignored.
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Option B: individual vars (local docker-compose only)
DB_HOST=localhost
DB_PORT=5432
DB_USER=scraper_user
DB_PASSWORD=change_me
DB_NAME=routes_db
